# ─── App / Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=
ADMIN_EMAIL=
DASHBOARD_ADMIN_SECRET=

# ─── Postgres ───────────────────────────────────────────────────────────────--
# Local dev (docker): postgres://portfolio:portfolio@localhost:5432/portfolio
DATABASE_URL=postgres://portfolio:portfolio@localhost:5432/portfolio
# Used by docker-compose to provision the db service:
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=
POSTGRES_DB=portfolio

# ─── Cloudflare R2 (S3-compatible API) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=portfolio
R2_PUBLIC_URL=https://cdn.afonsodev.com

# ─── IA (geração de contratos) ──────────────────────────────────────────────--
OPENAI_API_KEY=

# ─── Mercado Pago ───────────────────────────────────────────────────────────--
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=

# ─── Migração de dados D1 → Postgres (uso único, local) ─────────────────────────
# Caminho do export do D1 (SQLite) lido por scripts/migrate-d1-to-pg.mjs
D1_SQLITE_FILE=./scratchpad/d1-dump.sqlite
